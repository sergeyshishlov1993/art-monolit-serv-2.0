generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELED
}

enum AdminRole {
  ADMIN
  MANAGER
}

enum ProductBadge {
  NEW
  HIT
  SALE
}

model Category {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  description    String?
  imageUrl       String?
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  products       Product[]
  portfolioWorks PortfolioWork[]

  @@map("categories")
}

model TargetGroup {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  products       Product[]       @relation("ProductTargetGroups")
  portfolioWorks PortfolioWork[] @relation("PortfolioWorkTargetGroups")

  @@map("target_groups")
}

model Material {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  products       Product[]       @relation("ProductMaterials")
  portfolioWorks PortfolioWork[] @relation("PortfolioWorkMaterials")

  @@map("materials")
}

model Product {
  id              String         @id @default(uuid()) @db.Uuid
  categoryId      String         @db.Uuid
  title           String
  slug            String         @unique
  description     String?
  discountPercent Int?
  badges          ProductBadge[] @default([])
  isActive        Boolean        @default(true)
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  targetGroups    TargetGroup[]  @relation("ProductTargetGroups")
  materials       Material[]     @relation("ProductMaterials")
  images          ProductImage[]
  specs           ProductSpec[]
  leads           Lead[]

  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  s3Key     String
  url       String
  sortOrder Int      @default(0)
  alt       String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductSpec {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  key       String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_specs")
}

model HeroSlide {
  id         String   @id @default(uuid()) @db.Uuid
  title      String
  subtitle   String?
  buttonText String?
  buttonLink String?
  imageUrl   String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("hero_slides")
}

model PortfolioWork {
  id           String           @id @default(uuid()) @db.Uuid
  categoryId   String           @db.Uuid
  sortOrder    Int              @default(0)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  targetGroups TargetGroup[]    @relation("PortfolioWorkTargetGroups")
  materials    Material[]       @relation("PortfolioWorkMaterials")
  images       PortfolioImage[]

  @@index([categoryId])
  @@index([isActive])
  @@map("portfolio_works")
}

model PortfolioImage {
  id              String        @id @default(uuid()) @db.Uuid
  portfolioWorkId String        @db.Uuid
  s3Key           String
  url             String
  sortOrder       Int           @default(0)
  alt             String?
  createdAt       DateTime      @default(now())
  portfolioWork   PortfolioWork @relation(fields: [portfolioWorkId], references: [id], onDelete: Cascade)

  @@index([portfolioWorkId])
  @@map("portfolio_images")
}

model Lead {
  id           String     @id @default(uuid()) @db.Uuid
  number       Int        @default(autoincrement())
  name         String
  phone        String
  message      String?
  productId    String?    @db.Uuid
  status       LeadStatus @default(NEW)
  source       String     @default("site")
  pixel        String?
  adminComment String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  product      Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([source])
  @@map("leads")
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  role         AdminRole @default(MANAGER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}
